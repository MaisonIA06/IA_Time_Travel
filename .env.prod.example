# .env.prod.example
# Template pour le deploiement production.
# Copier vers .env.prod (qui est ignore par git) puis remplir chaque valeur.
#
#   cp .env.prod.example .env.prod
#
# IMPORTANT : ne jamais committer .env.prod (secrets !).

# ---------------------------------------------------------------------------
# Base de donnees PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=ia_timetravel
# TODO : choisir un utilisateur dedie (eviter "postgres" en prod)
POSTGRES_USER=ia_timetravel_user
# TODO : generer un mot de passe fort (ex: openssl rand -base64 32)
POSTGRES_PASSWORD=changeme-strong-password

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
# TODO : generer une cle secrete (ex: python -c "import secrets;print(secrets.token_urlsafe(64))")
SECRET_KEY=changeme-django-secret-key

# Hosts autorises (comma separated). Doit contenir le domaine public.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Origines CORS autorisees (comma separated, schema compris).
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# URL de connexion base. Le host "db" correspond au service docker-compose.
DATABASE_URL=postgres://ia_timetravel_user:changeme-strong-password@db:5432/ia_timetravel

# ---------------------------------------------------------------------------
# nginx / Let's Encrypt
# ---------------------------------------------------------------------------
# TODO : remplacer par votre domaine reel (FQDN pointe vers le VPS).
DOMAIN_NAME=example.com

# TODO : email valide pour les notifications d'expiration Let's Encrypt.
CERTBOT_EMAIL=admin@example.com
